<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#12151A"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Iniciando…"
        android:textColor="#828B94"
        android:textSize="13sp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvMeters"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FFB238"
        android:textSize="64sp"
        android:fontFamily="monospace"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="metros"
        android:textColor="#828B94"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvKm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0,00 km"
        android:textColor="#EEF0EE"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="40dp" />

    <TextView
        android:id="@+id/tvAccuracy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Precisión: —"
        android:textColor="#828B94"
        android:textSize="13sp"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnReset"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="Puesta a cero"
        android:textColor="#12151A"
        android:backgroundTint="#FFB238"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnCalibrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calibrar (100%)"
        android:textAllCaps="false"
        android:backgroundTint="#2A323B"
        android:textColor="#EEF0EE" />

</LinearLayout>
