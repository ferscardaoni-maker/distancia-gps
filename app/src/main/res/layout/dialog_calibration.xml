<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ingresá ambos valores comparando el mismo tramo recorrido."
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etAppDistance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Lo que marcó esta app (km)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/etRealDistance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Lo que marcó el odómetro del auto (km)"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp" />

</LinearLayout>
